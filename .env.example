# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3000/portal
API_URL=http://localhost:4000
PUBLIC_DOMAIN=localhost

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://onsec:onsec@localhost:5433/onsecboad?schema=public
DATABASE_REPLICA_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (server-only) ──────────────────────────────────────────────────────
# Use `openssl rand -hex 32` to generate
JWT_ACCESS_SECRET=replace-me-32-byte-hex
JWT_REFRESH_SECRET=replace-me-32-byte-hex
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# AES-256-GCM key (base64 32 bytes) for column encryption (TOTP secrets, Twilio creds)
ENCRYPTION_KEY_BASE64=

# WebAuthn / passkeys
WEBAUTHN_RP_NAME=OnsecBoad
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Hostinger example: smtp.hostinger.com / 465 / SSL.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=donotreply@onsective.com
SMTP_PASSWORD=replace-with-your-smtp-password
EMAIL_FROM_DEFAULT="OnsecBoad <donotreply@onsective.com>"
# If true, emails are not sent — the rendered message is logged instead.
EMAIL_DRY_RUN=false

# ─── Storage (Cloudflare R2 / S3) ────────────────────────────────────────────
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onsecboad-dev

# ─── Phase 1: Stripe billing ─────────────────────────────────────────────────
# Leave secret/webhook empty (or use 'sk_dummy_*') and set STRIPE_DRY_RUN=true
# to develop without a Stripe account — the client logs operations and returns
# plausible mock responses. Drop in real keys + flip STRIPE_DRY_RUN=false when
# the test mode account is ready.
STRIPE_SECRET_KEY=sk_dummy_secret
STRIPE_PUBLISHABLE_KEY=pk_dummy_publishable
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_DRY_RUN=true
STRIPE_TRIAL_DAYS=14
# stripePriceId per plan is stored in the Plan table (see prisma seed). The
# legacy STRIPE_PRICE_* vars are no longer read.

# ─── Phase 3 placeholders (set later) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_APP_SECRET=
TIKTOK_APP_SECRET=

# ─── Phase 8 placeholders ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Observability (optional) ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

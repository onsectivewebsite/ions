# ─── OnsecBoad production env (Hostinger VPS + CloudPanel) ─────────────────
# Copy to .env.production on the VPS and fill every value before
# `docker compose -f infra/docker/compose.prod.yml --env-file .env.production up -d --build`.

NODE_ENV=production

# ─── Public URLs ───────────────────────────────────────────────────────────
APP_URL=https://onsective.cloud
PORTAL_URL=https://onsective.cloud/portal
API_URL=https://api.onsective.cloud
PUBLIC_DOMAIN=onsective.cloud

# ─── Postgres (runs in compose; loopback-only) ─────────────────────────────
POSTGRES_USER=onsec
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=onsecboad

# ─── Auth secrets (use `openssl rand -hex 32` etc) ─────────────────────────
# These cannot be the dev defaults. Generate fresh on the VPS.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# AES-256-GCM key (base64 32 bytes) for column encryption
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY_BASE64=

# ─── WebAuthn (must match prod domain exactly) ─────────────────────────────
WEBAUTHN_RP_NAME=OnsecBoad
WEBAUTHN_RP_ID=onsective.cloud
WEBAUTHN_ORIGIN=https://onsective.cloud

# ─── Email (Hostinger SMTP) ────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=donotreply@onsective.com
SMTP_PASSWORD=
EMAIL_FROM_DEFAULT=OnsecBoad <donotreply@onsective.com>
EMAIL_DRY_RUN=false

# ─── Cloudflare R2 (object storage for invoice PDFs etc) ───────────────────
# Empty values → dry-run mode (no real upload). Fill once you create the bucket.
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ─── Stripe (real keys for production) ─────────────────────────────────────
# Set STRIPE_DRY_RUN=true while you're still testing on the VPS without
# real payment intent. Flip to false when launching for paying customers.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DRY_RUN=true
STRIPE_TRIAL_DAYS=14

# ─── Background jobs ───────────────────────────────────────────────────────
ENABLE_CRON=true
CRON_SEAT_RECONCILE=0 2 * * *

# ─── Phase 3+ (set when those phases land) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_APP_SECRET=
TIKTOK_APP_SECRET=
ANTHROPIC_API_KEY=

# ─── Observability (optional) ──────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

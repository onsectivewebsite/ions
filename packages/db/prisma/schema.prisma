// Onsective OnsecBoad — Prisma schema (Phase 0 + forward declarations)
// Source of truth: docs/02-data-model.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // node:20-alpine in the Docker image runs musl. argon2 also needs the
  // matching native binary — see apps/api/Dockerfile for the apk packages.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ─── Platform-level (not tenant-scoped) ─────────────────────────────────────

model PlatformUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.Citext
  name          String
  passwordHash  String?
  twoFASecret   String?
  isSuperadmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  passkeys      Passkey[]
  sessions      Session[]
}

model Tenant {
  id              String       @id @default(uuid()) @db.Uuid
  legalName       String
  displayName     String
  slug            String       @unique
  status          TenantStatus @default(PROVISIONING)
  packageTier     PackageTier  @default(STARTER)
  seatCount       Int          @default(0)
  branding        Json
  twilio          Json?
  meta            Json?
  tiktok          Json?
  emailFrom       String?
  locale          String       @default("en-CA")
  timezone        String       @default("America/Toronto")
  // Stripe (used in Phase 1)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  setupCompletedAt     DateTime?
  setupTokenHash       String?      @unique
  setupTokenExpiresAt  DateTime?
  planId               String?      @db.Uuid
  plan                 Plan?        @relation(fields: [planId], references: [id])
  invoices             SubscriptionInvoice[]
  // Billing entity details — surfaced on invoices, editable from /p/firms/[id]
  // (platform admin) or /settings/billing (firm admin).
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              Json?        // { line1, line2, city, province, postalCode, country }
  taxId                String?      // GST/HST/EIN — value only
  taxIdType            String?      // 'ca_gst_hst' | 'us_ein' | etc — Stripe type code
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  branches        Branch[]
  users           User[]
  roles           Role[]
  invites         Invite[]
  auditLogs       AuditLog[]
  // Phase 3 back-relations
  leads           Lead[]
  callLogs        CallLog[]
  smsLogs         SmsLog[]
  emailLogs       EmailLog[]
  campaigns       Campaign[]
  leadRules       LeadRule[]
  apiKeys         ApiKey[]
  // Phase 4 back-relations
  clients              Client[]
  intakeFormTemplates  IntakeFormTemplate[]
  intakeSubmissions    IntakeSubmission[]

  @@index([status])
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PackageTier {
  STARTER
  GROWTH
  SCALE
}

// ─── Tenant-scoped: org structure ───────────────────────────────────────────

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  name      String
  address   Json
  phone     String
  email     String?
  managerId String? @db.Uuid
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users     User[]  @relation("BranchUsers")
  leads     Lead[]
  clients   Client[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  email           String     @db.Citext
  name            String
  phone           String?
  passwordHash    String?
  twoFASecret     String?
  branchId        String?    @db.Uuid
  branch          Branch?    @relation("BranchUsers", fields: [branchId], references: [id])
  managedBranches Branch[]   @relation("BranchManager")
  roleId          String     @db.Uuid
  role            Role       @relation(fields: [roleId], references: [id])
  status          UserStatus @default(INVITED)
  isBillable      Boolean    @default(true)
  invitedAt       DateTime?
  joinedAt        DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  passkeys        Passkey[]
  sessions        Session[]
  assignedLeads   Lead[]    @relation("LeadAssignee")
  callsAsAgent    CallLog[] @relation("CallAgent")

  @@unique([tenantId, email])
  @@index([tenantId, roleId])
  @@index([tenantId, branchId])
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  isSystem    Boolean  @default(false)
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@unique([tenantId, name])
}

model Passkey {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @db.Uuid
  user            User?         @relation(fields: [userId], references: [id])
  platformUserId  String?       @db.Uuid
  platformUser    PlatformUser? @relation(fields: [platformUserId], references: [id])
  credentialId    Bytes         @unique
  publicKey       Bytes
  counter         Int
  deviceType      String
  transports      String[]
  createdAt       DateTime      @default(now())
  lastUsedAt      DateTime?
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String?       @db.Uuid
  user             User?         @relation(fields: [userId], references: [id])
  platformUserId   String?       @db.Uuid
  platformUser     PlatformUser? @relation(fields: [platformUserId], references: [id])
  refreshTokenHash String        @unique
  device           String
  ip               String
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  revokedAt        DateTime?
}

model Invite {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  email      String    @db.Citext
  roleId     String    @db.Uuid
  branchId   String?   @db.Uuid
  invitedBy  String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, email])
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @db.Uuid
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  actorId    String    @db.Uuid
  actorType  ActorType
  action     String
  targetType String
  targetId   String?   @db.Uuid
  payload    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
}

enum ActorType {
  PLATFORM
  USER
  CLIENT
  SYSTEM
}

// ─── Phase 1: Plans + billing ────────────────────────────────────────────────

model Plan {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique // STARTER | GROWTH | SCALE
  name               String
  pricePerSeatCents  BigInt
  currency           String   @default("CAD")
  stripePriceId      String   @unique
  limits             Json
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenants            Tenant[]
}

model SubscriptionInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  stripeInvoiceId String   @unique
  amountCents     BigInt
  currency        String
  periodStart     DateTime
  periodEnd       DateTime
  seatCount       Int
  status          String   // draft | open | paid | uncollectible | void
  pdfUrl          String?
  hostedUrl       String?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Idempotency log for webhook deliveries — Stripe retries; we record event.id once.
model WebhookEvent {
  id          String   @id // Stripe event.id
  source      String   // 'stripe'
  type        String   // event.type
  receivedAt  DateTime @default(now())
  processedAt DateTime?
  error       String?
  payload     Json?

  @@index([source, type])
}

// ─── Phase 3: Lead pipeline + CRM + Twilio ──────────────────────────────────

model Lead {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  branchId           String?      @db.Uuid
  branch             Branch?      @relation(fields: [branchId], references: [id])
  assignedToId       String?      @db.Uuid
  assignedTo         User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  // Lead identity
  firstName          String?
  lastName           String?
  email              String?      @db.Citext
  phone              String?      // E.164 preferred but free-form ok
  // Origin
  source             String       // 'meta' | 'tiktok' | 'website' | 'walkin' | 'referral' | 'manual' | 'import'
  sourceCampaignId   String?      @db.Uuid
  sourceCampaign     Campaign?    @relation("LeadSourceCampaign", fields: [sourceCampaignId], references: [id])
  externalId         String?      // platform-specific (Meta lead id, etc)
  // Lead state
  status             LeadStatus   @default(NEW)
  priority           Int          @default(50)
  language           String?      // ISO 639-1: 'en', 'pa', 'hi', 'fr', etc
  caseInterest       String?      // 'work_permit', 'study_permit', 'pr', etc
  notes              String?
  payload            Json?        // platform-native form fields
  // Compliance
  dncFlag            Boolean      @default(false)
  consentMarketing   Boolean      @default(false)
  // Activity timestamps
  lastContactedAt    DateTime?
  followupDueAt      DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  callLogs           CallLog[]
  smsLogs            SmsLog[]
  emailLogs          EmailLog[]
  leadCampaigns      LeadCampaign[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, branchId, assignedToId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@unique([tenantId, source, externalId])
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOWUP
  INTERESTED
  BOOKED
  CONVERTED
  LOST
  DNC
}

model CallLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  agent           User?      @relation("CallAgent", fields: [agentId], references: [id])
  twilioSid       String?    @unique
  direction       String     // 'outbound' | 'inbound'
  fromNumber      String?
  toNumber        String?
  status          String     // 'queued' | 'ringing' | 'in-progress' | 'completed' | 'busy' | 'no-answer' | 'failed'
  durationSec     Int?
  recordingUrl    String?    // r2:// pointer
  recordingSid    String?
  disposition     String?    // 'interested' | 'not_interested' | 'voicemail' | 'callback' | 'wrong_number' | 'dnc' | 'booked'
  notes           String?
  startedAt       DateTime   @default(now())
  endedAt         DateTime?

  @@index([tenantId, agentId, startedAt])
  @@index([tenantId, leadId, startedAt])
}

model SmsLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  twilioSid       String?    @unique
  direction       String     // 'outbound' | 'inbound'
  fromNumber      String?
  toNumber        String?
  body            String
  status          String     // 'queued' | 'sent' | 'delivered' | 'failed' | 'received'
  createdAt       DateTime   @default(now())

  @@index([tenantId, leadId, createdAt])
}

model EmailLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  toEmail         String
  fromEmail       String
  subject         String
  body            String
  templateKey     String?
  status          String     // 'sent' | 'failed' | 'opened' | 'clicked'
  providerId      String?    @unique // SES/Resend message id
  createdAt       DateTime   @default(now())

  @@index([tenantId, leadId, createdAt])
}

model Campaign {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  branchId        String?    @db.Uuid
  name            String
  channel         String     // 'sms' | 'email' | 'meta' | 'tiktok' | 'manual'
  status          String     @default("draft") // 'draft' | 'scheduled' | 'running' | 'completed' | 'paused'
  audienceJson    Json?      // segmentation config
  templateKey     String?
  body            String?
  startsAt        DateTime?
  endsAt          DateTime?
  createdBy       String     @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  leadCampaigns   LeadCampaign[]
  sourcedLeads    Lead[]     @relation("LeadSourceCampaign")

  @@index([tenantId, status])
}

model LeadCampaign {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  leadId          String     @db.Uuid
  lead            Lead       @relation(fields: [leadId], references: [id])
  campaignId      String     @db.Uuid
  campaign        Campaign   @relation(fields: [campaignId], references: [id])
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  unsubscribedAt  DateTime?

  @@unique([leadId, campaignId])
  @@index([tenantId, campaignId])
}

model LeadRule {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  priority    Int        // lower = first
  name        String
  matchJson   Json       // {source?, language?, branchId?, hourRange?}
  actionJson  Json       // {assignTo: 'round_robin'|'user', userId?, branchId?}
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId, priority])
}

model ApiKey {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  name        String
  keyHash     String     @unique
  keyPrefix   String     // first 8 chars for display ("osk_abcd…")
  scopes      String[]   // 'leads:write', 'leads:read', etc
  createdBy   String     @db.Uuid
  createdAt   DateTime   @default(now())
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  @@index([tenantId, revokedAt])
}

// ─── Phase 4: Clients + Intake forms ────────────────────────────────────────

model Client {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  branchId        String?    @db.Uuid
  branch          Branch?    @relation(fields: [branchId], references: [id])
  // Identity — phone is the canonical key (per docs/01-domain.md invariant).
  firstName       String?
  lastName        String?
  email           String?    @db.Citext
  phone           String     // E.164 preferred — required for receptionist match flow
  language        String?
  // Linkage back to the lead that created this client (for traceability).
  primaryLeadId   String?    @db.Uuid
  // Notes are receptionist/admin scratch — case-management notes live elsewhere.
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  intakeSubmissions IntakeSubmission[]

  // One canonical client row per (firm, phone). Re-arrival lookups hit this index.
  @@unique([tenantId, phone])
  @@index([tenantId, lastName])
  @@index([tenantId, email])
}

// IntakeFormTemplate — per-firm, per-case-type form schema.
// `fieldsJson` shape: [{ key, label, type, required?, placeholder?, helpText?, options?, maxLength? }]
// type ∈ 'text'|'email'|'phone'|'date'|'number'|'textarea'|'select'|'multiselect'|'checkbox'|'file'.
// Built-in case types: 'work_permit', 'study_permit', 'pr', 'visitor_visa',
// 'citizenship', 'lmia', 'other'. Stored as a string (not enum) so firms can
// extend without a schema migration.
model IntakeFormTemplate {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  caseType    String
  name        String
  description String?
  fieldsJson  Json
  isActive    Boolean    @default(true)
  createdBy   String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  submissions IntakeSubmission[]

  @@index([tenantId, caseType, isActive])
}

// IntakeSubmission — the filled-out form. Created either:
//   - Inline by a staff member (submittedBy = userId, publicTokenHash null)
//   - Self-served by a client via /intake/<token> (submittedBy null, publicSubmittedAt set)
// We carry leadId AND clientId on purpose: a submission against a brand-new walk-in
// starts with leadId only; once we promote them to a Client (after intake completes)
// we backfill clientId so client history queries see it.
model IntakeSubmission {
  id                   String     @id @default(uuid()) @db.Uuid
  tenantId             String     @db.Uuid
  tenant               Tenant     @relation(fields: [tenantId], references: [id])
  templateId           String     @db.Uuid
  template             IntakeFormTemplate @relation(fields: [templateId], references: [id])
  caseType             String
  leadId               String?    @db.Uuid
  clientId             String?    @db.Uuid
  client               Client?    @relation(fields: [clientId], references: [id])
  fieldsJson           Json
  submittedBy          String?    @db.Uuid
  submittedAt          DateTime   @default(now())
  // Self-fill via public link (4.x slice; nullable for inline submissions).
  publicTokenHash      String?    @unique
  publicTokenExpiresAt DateTime?
  publicSubmittedAt    DateTime?

  @@index([tenantId, leadId])
  @@index([tenantId, clientId, submittedAt])
}

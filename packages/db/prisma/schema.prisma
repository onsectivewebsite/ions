// Onsective OnsecBoad — Prisma schema (Phase 0 + forward declarations)
// Source of truth: docs/02-data-model.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // node:20-alpine in the Docker image runs musl. argon2 also needs the
  // matching native binary — see apps/api/Dockerfile for the apk packages.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ─── Platform-level (not tenant-scoped) ─────────────────────────────────────

model PlatformUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.Citext
  name          String
  passwordHash  String?
  twoFASecret   String?
  isSuperadmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  passkeys      Passkey[]
  sessions      Session[]
}

model Tenant {
  id              String       @id @default(uuid()) @db.Uuid
  legalName       String
  displayName     String
  slug            String       @unique
  status          TenantStatus @default(PROVISIONING)
  packageTier     PackageTier  @default(STARTER)
  seatCount       Int          @default(0)
  branding        Json
  twilio          Json?
  emailFrom       String?
  locale          String       @default("en-CA")
  timezone        String       @default("America/Toronto")
  // Stripe (used in Phase 1)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  setupCompletedAt     DateTime?
  setupTokenHash       String?      @unique
  setupTokenExpiresAt  DateTime?
  planId               String?      @db.Uuid
  plan                 Plan?        @relation(fields: [planId], references: [id])
  invoices             SubscriptionInvoice[]
  // Billing entity details — surfaced on invoices, editable from /p/firms/[id]
  // (platform admin) or /settings/billing (firm admin).
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              Json?        // { line1, line2, city, province, postalCode, country }
  taxId                String?      // GST/HST/EIN — value only
  taxIdType            String?      // 'ca_gst_hst' | 'us_ein' | etc — Stripe type code
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  branches        Branch[]
  users           User[]
  roles           Role[]
  invites         Invite[]
  auditLogs       AuditLog[]

  @@index([status])
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PackageTier {
  STARTER
  GROWTH
  SCALE
}

// ─── Tenant-scoped: org structure ───────────────────────────────────────────

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  name      String
  address   Json
  phone     String
  email     String?
  managerId String? @db.Uuid
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users     User[]  @relation("BranchUsers")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  email           String     @db.Citext
  name            String
  phone           String?
  passwordHash    String?
  twoFASecret     String?
  branchId        String?    @db.Uuid
  branch          Branch?    @relation("BranchUsers", fields: [branchId], references: [id])
  managedBranches Branch[]   @relation("BranchManager")
  roleId          String     @db.Uuid
  role            Role       @relation(fields: [roleId], references: [id])
  status          UserStatus @default(INVITED)
  isBillable      Boolean    @default(true)
  invitedAt       DateTime?
  joinedAt        DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  passkeys        Passkey[]
  sessions        Session[]

  @@unique([tenantId, email])
  @@index([tenantId, roleId])
  @@index([tenantId, branchId])
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  isSystem    Boolean  @default(false)
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@unique([tenantId, name])
}

model Passkey {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @db.Uuid
  user            User?         @relation(fields: [userId], references: [id])
  platformUserId  String?       @db.Uuid
  platformUser    PlatformUser? @relation(fields: [platformUserId], references: [id])
  credentialId    Bytes         @unique
  publicKey       Bytes
  counter         Int
  deviceType      String
  transports      String[]
  createdAt       DateTime      @default(now())
  lastUsedAt      DateTime?
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String?       @db.Uuid
  user             User?         @relation(fields: [userId], references: [id])
  platformUserId   String?       @db.Uuid
  platformUser     PlatformUser? @relation(fields: [platformUserId], references: [id])
  refreshTokenHash String        @unique
  device           String
  ip               String
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  revokedAt        DateTime?
}

model Invite {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  email      String    @db.Citext
  roleId     String    @db.Uuid
  branchId   String?   @db.Uuid
  invitedBy  String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, email])
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @db.Uuid
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  actorId    String    @db.Uuid
  actorType  ActorType
  action     String
  targetType String
  targetId   String?   @db.Uuid
  payload    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
}

enum ActorType {
  PLATFORM
  USER
  CLIENT
  SYSTEM
}

// ─── Phase 1: Plans + billing ────────────────────────────────────────────────

model Plan {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique // STARTER | GROWTH | SCALE
  name               String
  pricePerSeatCents  BigInt
  currency           String   @default("CAD")
  stripePriceId      String   @unique
  limits             Json
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenants            Tenant[]
}

model SubscriptionInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  stripeInvoiceId String   @unique
  amountCents     BigInt
  currency        String
  periodStart     DateTime
  periodEnd       DateTime
  seatCount       Int
  status          String   // draft | open | paid | uncollectible | void
  pdfUrl          String?
  hostedUrl       String?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Idempotency log for webhook deliveries — Stripe retries; we record event.id once.
model WebhookEvent {
  id          String   @id // Stripe event.id
  source      String   // 'stripe'
  type        String   // event.type
  receivedAt  DateTime @default(now())
  processedAt DateTime?
  error       String?
  payload     Json?

  @@index([source, type])
}

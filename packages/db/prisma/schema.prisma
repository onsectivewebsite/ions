// Onsective OnsecBoad — Prisma schema (Phase 0 + forward declarations)
// Source of truth: docs/02-data-model.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // node:20-alpine in the Docker image runs musl. argon2 also needs the
  // matching native binary — see apps/api/Dockerfile for the apk packages.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ─── Platform-level (not tenant-scoped) ─────────────────────────────────────

model PlatformUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.Citext
  name          String
  passwordHash  String?
  twoFASecret   String?
  isSuperadmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  passkeys      Passkey[]
  sessions      Session[]
}

model Tenant {
  id              String       @id @default(uuid()) @db.Uuid
  legalName       String
  displayName     String
  slug            String       @unique
  status          TenantStatus @default(PROVISIONING)
  packageTier     PackageTier  @default(STARTER)
  seatCount       Int          @default(0)
  branding        Json
  twilio          Json?
  meta            Json?
  tiktok          Json?
  emailFrom       String?
  locale          String       @default("en-CA")
  timezone        String       @default("America/Toronto")
  // Stripe (used in Phase 1)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  setupCompletedAt     DateTime?
  setupTokenHash       String?      @unique
  setupTokenExpiresAt  DateTime?
  planId               String?      @db.Uuid
  plan                 Plan?        @relation(fields: [planId], references: [id])
  invoices             SubscriptionInvoice[]
  // Billing entity details — surfaced on invoices, editable from /p/firms/[id]
  // (platform admin) or /settings/billing (firm admin).
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              Json?        // { line1, line2, city, province, postalCode, country }
  taxId                String?      // GST/HST/EIN — value only
  taxIdType            String?      // 'ca_gst_hst' | 'us_ein' | etc — Stripe type code
  // PIPEDA-relevant. Default 730 (2 years) matches s.10.3 record-keeping.
  auditRetentionDays   Int          @default(730)
  // Per-firm feature flags ({ [key]: boolean }) + active announcement
  // ({ message, level: 'info' | 'warning' | 'urgent', expiresAt }).
  featureFlags         Json?
  announcement         Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  branches        Branch[]
  users           User[]
  roles           Role[]
  invites         Invite[]
  auditLogs       AuditLog[]
  // Phase 3 back-relations
  leads           Lead[]
  callLogs        CallLog[]
  smsLogs         SmsLog[]
  emailLogs       EmailLog[]
  campaigns       Campaign[]
  leadRules       LeadRule[]
  apiKeys         ApiKey[]
  // Phase 4 back-relations
  clients              Client[]
  intakeFormTemplates  IntakeFormTemplate[]
  intakeSubmissions    IntakeSubmission[]
  appointments         Appointment[]
  // Phase 5 back-relations
  cases                Case[]
  retainerTemplates    RetainerTemplate[]
  retainerAgreements   RetainerAgreement[]
  documentChecklistTemplates DocumentChecklistTemplate[]
  documentCollections        DocumentCollection[]
  documentUploads            DocumentUpload[]
  irccCorrespondence         IrccCorrespondence[]
  clientPortalAccounts       ClientPortalAccount[]
  // Phase 6 back-relations
  caseAiData                 CaseAiData[]
  pdfFormTemplates           PdfFormTemplate[]
  generatedDocuments         GeneratedDocument[]
  // Phase 7 back-relations
  caseInvoices               CaseInvoice[]
  casePayments               CasePayment[]
  messages                   Message[]
  // Phase 8 back-relations
  aiSettings                 AiSettings?
  aiUsage                    AiUsage[]
  aiAgentRuns                AiAgentRun[]
  // Phase 9.5 back-relations
  pushDevices                PushDevice[]
  // Phase 10.1 back-relations
  suppression                SuppressionEntry[]

  @@index([status])
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PackageTier {
  STARTER
  GROWTH
  SCALE
}

// ─── Tenant-scoped: org structure ───────────────────────────────────────────

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  name      String
  address   Json
  phone     String
  email     String?
  managerId String? @db.Uuid
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users     User[]  @relation("BranchUsers")
  leads     Lead[]
  clients   Client[]
  appointments Appointment[]
  cases     Case[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  email           String     @db.Citext
  name            String
  phone           String?
  passwordHash    String?
  twoFASecret     String?
  recoveryCodes   TwoFactorRecoveryCode[]
  notificationPrefs Json?
  branchId        String?    @db.Uuid
  branch          Branch?    @relation("BranchUsers", fields: [branchId], references: [id])
  managedBranches Branch[]   @relation("BranchManager")
  roleId          String     @db.Uuid
  role            Role       @relation(fields: [roleId], references: [id])
  status          UserStatus @default(INVITED)
  isBillable      Boolean    @default(true)
  invitedAt       DateTime?
  joinedAt        DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  passkeys        Passkey[]
  sessions        Session[]
  assignedLeads   Lead[]    @relation("LeadAssignee")
  callsAsAgent    CallLog[] @relation("CallAgent")
  appointmentsAsProvider Appointment[] @relation("AppointmentProvider")
  casesAsLawyer   Case[]    @relation("CaseLawyer")
  casesAsFiler    Case[]    @relation("CaseFiler")
  retainersApproved RetainerAgreement[] @relation("RetainerApprovedBy")
  pushDevices     PushDevice[]

  @@unique([tenantId, email])
  @@index([tenantId, roleId])
  @@index([tenantId, branchId])
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  isSystem    Boolean  @default(false)
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@unique([tenantId, name])
}

model Passkey {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @db.Uuid
  user            User?         @relation(fields: [userId], references: [id])
  platformUserId  String?       @db.Uuid
  platformUser    PlatformUser? @relation(fields: [platformUserId], references: [id])
  credentialId    Bytes         @unique
  publicKey       Bytes
  counter         Int
  deviceType      String
  transports      String[]
  createdAt       DateTime      @default(now())
  lastUsedAt      DateTime?
}

// 2FA recovery codes — single-use printable codes for "lost authenticator
// device" recovery. Generated on TOTP enrollment, hashed at rest, marked
// used the first time they're consumed.
model TwoFactorRecoveryCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, usedAt])
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String?       @db.Uuid
  user             User?         @relation(fields: [userId], references: [id])
  platformUserId   String?       @db.Uuid
  platformUser     PlatformUser? @relation(fields: [platformUserId], references: [id])
  refreshTokenHash String        @unique
  device           String
  ip               String
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  revokedAt        DateTime?
}

model Invite {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  email      String    @db.Citext
  roleId     String    @db.Uuid
  branchId   String?   @db.Uuid
  invitedBy  String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, email])
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @db.Uuid
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  actorId    String    @db.Uuid
  actorType  ActorType
  action     String
  targetType String
  targetId   String?   @db.Uuid
  payload    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
}

enum ActorType {
  PLATFORM
  USER
  CLIENT
  SYSTEM
}

// ─── Phase 1: Plans + billing ────────────────────────────────────────────────

model Plan {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique // STARTER | GROWTH | SCALE
  name               String
  pricePerSeatCents  BigInt
  currency           String   @default("CAD")
  stripePriceId      String   @unique
  limits             Json
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenants            Tenant[]
}

model SubscriptionInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  stripeInvoiceId String   @unique
  amountCents     BigInt
  currency        String
  periodStart     DateTime
  periodEnd       DateTime
  seatCount       Int
  status          String   // draft | open | paid | uncollectible | void
  pdfUrl          String?
  hostedUrl       String?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Idempotency log for webhook deliveries — Stripe retries; we record event.id once.
model WebhookEvent {
  id          String   @id // Stripe event.id
  source      String   // 'stripe'
  type        String   // event.type
  receivedAt  DateTime @default(now())
  processedAt DateTime?
  error       String?
  payload     Json?

  @@index([source, type])
}

// ─── Phase 3: Lead pipeline + CRM + Twilio ──────────────────────────────────

model Lead {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  branchId           String?      @db.Uuid
  branch             Branch?      @relation(fields: [branchId], references: [id])
  assignedToId       String?      @db.Uuid
  assignedTo         User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  // Lead identity
  firstName          String?
  lastName           String?
  email              String?      @db.Citext
  phone              String?      // E.164 preferred but free-form ok
  // Origin
  source             String       // 'meta' | 'tiktok' | 'website' | 'walkin' | 'referral' | 'manual' | 'import'
  sourceCampaignId   String?      @db.Uuid
  sourceCampaign     Campaign?    @relation("LeadSourceCampaign", fields: [sourceCampaignId], references: [id])
  externalId         String?      // platform-specific (Meta lead id, etc)
  // Lead state
  status             LeadStatus   @default(NEW)
  priority           Int          @default(50)
  language           String?      // ISO 639-1: 'en', 'pa', 'hi', 'fr', etc
  caseInterest       String?      // 'work_permit', 'study_permit', 'pr', etc
  notes              String?
  payload            Json?        // platform-native form fields
  // Compliance
  dncFlag            Boolean      @default(false)
  consentMarketing   Boolean      @default(false)
  // Activity timestamps
  lastContactedAt    DateTime?
  followupDueAt      DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  callLogs           CallLog[]
  smsLogs            SmsLog[]
  emailLogs          EmailLog[]
  leadCampaigns      LeadCampaign[]
  appointments       Appointment[]
  cases              Case[]
  intakeRequests     IntakeRequest[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, branchId, assignedToId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@unique([tenantId, source, externalId])
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOWUP
  INTERESTED
  BOOKED
  CONVERTED
  LOST
  DNC
}

model CallLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  agent           User?      @relation("CallAgent", fields: [agentId], references: [id])
  twilioSid       String?    @unique
  direction       String     // 'outbound' | 'inbound'
  fromNumber      String?
  toNumber        String?
  status          String     // 'queued' | 'ringing' | 'in-progress' | 'completed' | 'busy' | 'no-answer' | 'failed'
  durationSec     Int?
  recordingUrl    String?    // r2:// pointer
  recordingSid    String?
  disposition     String?    // 'interested' | 'not_interested' | 'voicemail' | 'callback' | 'wrong_number' | 'dnc' | 'booked'
  notes           String?
  // Phase 8.4 — call transcription + AI summary.
  transcript      String?    @db.Text
  transcriptSource String?   // 'twilio' | 'whisper' | 'stub'
  aiSummary       String?    @db.Text
  aiSummarizedAt  DateTime?
  aiSummaryMode   String?    // 'real' | 'dry-run'
  startedAt       DateTime   @default(now())
  endedAt         DateTime?

  @@index([tenantId, agentId, startedAt])
  @@index([tenantId, leadId, startedAt])
}

model SmsLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  twilioSid       String?    @unique
  direction       String     // 'outbound' | 'inbound'
  fromNumber      String?
  toNumber        String?
  body            String
  status          String     // 'queued' | 'sent' | 'delivered' | 'failed' | 'received'
  createdAt       DateTime   @default(now())

  @@index([tenantId, leadId, createdAt])
}

model EmailLog {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  agentId         String?    @db.Uuid
  toEmail         String
  fromEmail       String
  subject         String
  body            String
  templateKey     String?
  // 'sent' | 'failed' | 'delivered' | 'bounced' | 'complained' | 'opened' | 'clicked'
  status          String
  providerId      String?    @unique // SES/Resend/Postmark message id
  // Deliverability tracking — populated by /api/v1/webhooks/email when
  // the SMTP provider (Postmark/SendGrid/Resend/SES) calls back.
  deliveredAt     DateTime?
  bouncedAt       DateTime?
  bounceType      String?    // 'hard' | 'soft' | 'undetermined'
  bounceReason    String?
  complainedAt    DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime   @default(now())

  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, status, createdAt])
}

model Campaign {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  branchId        String?    @db.Uuid
  name            String
  channel         String     // 'sms' | 'email' | 'meta' | 'tiktok' | 'manual'
  status          String     @default("draft") // 'draft' | 'scheduled' | 'running' | 'completed' | 'paused'
  audienceJson    Json?      // segmentation config
  templateKey     String?
  body            String?
  startsAt        DateTime?
  endsAt          DateTime?
  createdBy       String     @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  leadCampaigns   LeadCampaign[]
  sourcedLeads    Lead[]     @relation("LeadSourceCampaign")

  @@index([tenantId, status])
}

model LeadCampaign {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  leadId          String     @db.Uuid
  lead            Lead       @relation(fields: [leadId], references: [id])
  campaignId      String     @db.Uuid
  campaign        Campaign   @relation(fields: [campaignId], references: [id])
  sentAt          DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  unsubscribedAt  DateTime?

  @@unique([leadId, campaignId])
  @@index([tenantId, campaignId])
}

model LeadRule {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  priority    Int        // lower = first
  name        String
  matchJson   Json       // {source?, language?, branchId?, hourRange?}
  actionJson  Json       // {assignTo: 'round_robin'|'user', userId?, branchId?}
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId, priority])
}

model ApiKey {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  name        String
  keyHash     String     @unique
  keyPrefix   String     // first 8 chars for display ("osk_abcd…")
  scopes      String[]   // 'leads:write', 'leads:read', etc
  createdBy   String     @db.Uuid
  createdAt   DateTime   @default(now())
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  @@index([tenantId, revokedAt])
}

// ─── Phase 4: Clients + Intake forms ────────────────────────────────────────

model Client {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  branchId        String?    @db.Uuid
  branch          Branch?    @relation(fields: [branchId], references: [id])
  // Identity — phone is the canonical key (per docs/01-domain.md invariant).
  firstName       String?
  lastName        String?
  email           String?    @db.Citext
  phone           String     // E.164 preferred — required for receptionist match flow
  language        String?
  // Linkage back to the lead that created this client (for traceability).
  primaryLeadId   String?    @db.Uuid
  // Notes are receptionist/admin scratch — case-management notes live elsewhere.
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  // Phase 10.1 PIPEDA right-to-deletion:
  //   purgeAt is set when the firm initiates deletion; the daily cron
  //   anonymises PII + hard-deletes sub-records once `now() >= purgeAt`
  //   AND legalHoldUntil is null (or in the past). Setting purgeAt does
  //   NOT immediately wipe — there's a 30-day grace by default.
  purgeAt         DateTime?
  legalHoldUntil  DateTime?
  deletionReason  String?

  intakeSubmissions IntakeSubmission[]
  intakeRequests    IntakeRequest[]
  appointments      Appointment[]
  cases             Case[]
  portalAccount     ClientPortalAccount?
  messages          Message[]

  // One canonical client row per (firm, phone). Re-arrival lookups hit this index.
  @@unique([tenantId, phone])
  @@index([tenantId, lastName])
  @@index([tenantId, email])
}

// IntakeFormTemplate — per-firm, per-case-type form schema.
// `fieldsJson` shape: [{ key, label, type, required?, placeholder?, helpText?, options?, maxLength? }]
// type ∈ 'text'|'email'|'phone'|'date'|'number'|'textarea'|'select'|'multiselect'|'checkbox'|'file'.
// Built-in case types: 'work_permit', 'study_permit', 'pr', 'visitor_visa',
// 'citizenship', 'lmia', 'other'. Stored as a string (not enum) so firms can
// extend without a schema migration.
model IntakeFormTemplate {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  caseType    String
  name        String
  description String?
  fieldsJson  Json
  isActive    Boolean    @default(true)
  createdBy   String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  submissions IntakeSubmission[]
  requests    IntakeRequest[]

  @@index([tenantId, caseType, isActive])
}

// IntakeSubmission — the filled-out form. Created either:
//   - Inline by a staff member (submittedBy = userId, publicTokenHash null)
//   - Self-served by a client via /intake/<token> (submittedBy null, publicSubmittedAt set)
// We carry leadId AND clientId on purpose: a submission against a brand-new walk-in
// starts with leadId only; once we promote them to a Client (after intake completes)
// we backfill clientId so client history queries see it.
//
// `lockedAt` set when the client finishes filling. Only firm admin or branch
// manager can `intake.unlock` to allow further edits. Public link redirects
// to a "submitted" page when locked.
model IntakeSubmission {
  id                   String     @id @default(uuid()) @db.Uuid
  tenantId             String     @db.Uuid
  tenant               Tenant     @relation(fields: [tenantId], references: [id])
  templateId           String     @db.Uuid
  template             IntakeFormTemplate @relation(fields: [templateId], references: [id])
  caseType             String
  leadId               String?    @db.Uuid
  clientId             String?    @db.Uuid
  client               Client?    @relation(fields: [clientId], references: [id])
  fieldsJson           Json
  submittedBy          String?    @db.Uuid
  submittedAt          DateTime   @default(now())
  // Self-fill via public link (4.x slice; nullable for inline submissions).
  publicTokenHash      String?    @unique
  publicTokenExpiresAt DateTime?
  publicSubmittedAt    DateTime?
  lockedAt             DateTime?
  unlockedBy           String?    @db.Uuid
  unlockedAt           DateTime?

  request              IntakeRequest?

  @@index([tenantId, leadId])
  @@index([tenantId, clientId, submittedAt])
}

// IntakeRequest — a staff-issued invitation for a client to fill an intake
// form. Holds the public token, recipient delivery info, and the link back
// to the submission once filled. Distinct from IntakeSubmission because we
// want the "form sent but not yet filled" state to be queryable.
model IntakeRequest {
  id                   String     @id @default(uuid()) @db.Uuid
  tenantId             String     @db.Uuid
  tenant               Tenant     @relation(fields: [tenantId], references: [id])
  templateId           String     @db.Uuid
  template             IntakeFormTemplate @relation(fields: [templateId], references: [id])
  leadId               String?    @db.Uuid
  lead                 Lead?      @relation(fields: [leadId], references: [id])
  clientId             String?    @db.Uuid
  client               Client?    @relation(fields: [clientId], references: [id])

  recipientName        String?
  recipientEmail       String?
  recipientPhone       String?
  // 'email' | 'sms' | 'qr' | 'staff' (last = receptionist hands the tablet over)
  sentVia              String

  publicTokenHash      String     @unique
  publicTokenExpiresAt DateTime
  openedAt             DateTime?
  filledAt             DateTime?
  cancelledAt          DateTime?

  submissionId         String?    @unique @db.Uuid
  submission           IntakeSubmission? @relation(fields: [submissionId], references: [id])

  createdBy            String     @db.Uuid
  createdAt            DateTime   @default(now())

  @@index([tenantId, leadId])
  @@index([tenantId, clientId])
  @@index([tenantId, filledAt])
}

// Appointment — consultation, follow-up, document review, walk-in.
// State machine:
//   SCHEDULED → CONFIRMED → ARRIVED → IN_PROGRESS → COMPLETED
//                  ↘  CANCELLED  ↗
//                  ↘  NO_SHOW
// Outcome is recorded once status reaches COMPLETED. RETAINER → kicks off
// case-management (Phase 5); FOLLOWUP bounces the lead back to FOLLOWUP;
// DONE closes the lead as CONVERTED (consult fulfilled, no further work).
model Appointment {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  branchId        String?    @db.Uuid
  branch          Branch?    @relation(fields: [branchId], references: [id])
  clientId        String?    @db.Uuid
  client          Client?    @relation(fields: [clientId], references: [id])
  leadId          String?    @db.Uuid
  lead            Lead?      @relation(fields: [leadId], references: [id])
  providerId      String     @db.Uuid
  provider        User       @relation("AppointmentProvider", fields: [providerId], references: [id])
  scheduledAt     DateTime
  durationMin     Int        @default(30)
  kind            String     // 'consultation' | 'followup' | 'document_review' | 'walkin'
  caseType        String?    // matches IntakeFormTemplate.caseType vocabulary
  status          AppointmentStatus @default(SCHEDULED)
  arrivedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  // Money (Phase 4 captures intent; payment processing is Phase 7).
  feeCents        Int?
  paidAt          DateTime?
  paymentMethod   String?    // 'card' | 'cash' | 'etransfer' | 'invoice'
  // Outcome (recorded after consult).
  outcome         AppointmentOutcome?
  outcomeNotes    String?
  retainerFeeCents Int?      // when outcome=RETAINER, the agreed retainer
  notes           String?
  // Phase 8.4 — AI consultation summary (LLM-generated from notes/outcomeNotes).
  aiSummary       String?    @db.Text
  aiSummarizedAt  DateTime?
  aiSummaryMode   String?    // 'real' | 'dry-run'
  createdBy       String     @db.Uuid
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([tenantId, scheduledAt])
  @@index([tenantId, providerId, scheduledAt])
  @@index([tenantId, branchId, scheduledAt])
  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, leadId])
  @@index([tenantId, clientId])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentOutcome {
  RETAINER
  FOLLOWUP
  DONE
  NO_SHOW
}

// ─── Phase 5: Case management ──────────────────────────────────────────────

// Case represents a retained matter — created when an appointment outcome
// is RETAINER. State machine drives the workflow from retainer signature
// through document collection, lawyer approval, IRCC submission, and final
// outcome. Hard rule: feesCleared must be true before SUBMITTED_TO_IRCC.
model Case {
  id                 String     @id @default(uuid()) @db.Uuid
  tenantId           String     @db.Uuid
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  branchId           String?    @db.Uuid
  branch             Branch?    @relation(fields: [branchId], references: [id])
  // Subject
  clientId           String     @db.Uuid
  client             Client     @relation(fields: [clientId], references: [id])
  leadId             String?    @db.Uuid
  lead               Lead?      @relation(fields: [leadId], references: [id])
  appointmentId      String?    @db.Uuid    // origin consult
  caseType           String     // 'work_permit' | 'study_permit' | etc — same vocab as intake template
  // Assignments
  lawyerId           String     @db.Uuid
  lawyer             User       @relation("CaseLawyer", fields: [lawyerId], references: [id])
  filerId            String?    @db.Uuid
  filer              User?      @relation("CaseFiler", fields: [filerId], references: [id])
  // Status
  status             CaseStatus @default(PENDING_RETAINER)
  // Money — feesCleared is a derived flag we maintain on every payment update
  retainerFeeCents   Int?       // agreed-upon retainer at outcome time
  totalFeeCents      Int?       // full file fee (set later, ≥ retainer)
  amountPaidCents    Int        @default(0)
  feesCleared        Boolean    @default(false)
  // IRCC tracking — manual fields, no public API to verify
  usiNumber          String?    // unique session ID
  irccFileNumber     String?    // IRCC's case number once submitted
  irccPortalDate     DateTime?  // when uploaded to IRCC portal
  irccDecision       String?    // 'approved' | 'refused' | 'withdrawn' | etc
  // Lifecycle timestamps — one per major transition for visibility
  retainerApprovedAt DateTime?  // lawyer approved retainer terms
  retainerSignedAt   DateTime?  // client signed retainer
  documentsLockedAt  DateTime?  // client submitted all docs; collection link locked
  lawyerApprovedAt   DateTime?  // lawyer approved assembled file
  submittedToIrccAt  DateTime?  // case.transition → SUBMITTED_TO_IRCC
  completedAt        DateTime?  // final outcome
  closedReason       String?    // for WITHDRAWN / ABANDONED
  notes              String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  // Phase 7 back-relations
  invoices           CaseInvoice[]
  payments           CasePayment[]
  messages           Message[]
  // Phase 8.3 back-relations
  aiAgentRuns        AiAgentRun[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, lawyerId, status])
  @@index([tenantId, filerId, status])
}

enum CaseStatus {
  PENDING_RETAINER             // retainer drafted, awaiting lawyer approval
  PENDING_RETAINER_SIGNATURE   // lawyer approved, awaiting client signature
  PENDING_DOCUMENTS            // signed; filer collecting docs from client
  PREPARING                    // filer assembling the file
  PENDING_LAWYER_APPROVAL      // file ready for lawyer's final review
  SUBMITTED_TO_IRCC            // uploaded to IRCC portal
  IN_REVIEW                    // IRCC reviewing
  COMPLETED                    // approved / finalized
  WITHDRAWN                    // client withdrew
  ABANDONED                    // client abandoned (no comms / no payment)
}

// Retainer template — boilerplate per case type. {{merge.tags}} get
// substituted server-side when an Agreement is instantiated for a case.
// One default per (tenant, caseType=null) is the firm-wide fallback when
// a case-type-specific template doesn't exist.
model RetainerTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  // null caseType = firm-wide default fallback.
  caseType    String?
  name        String
  description String?
  contentMd   String   @db.Text  // Markdown body with {{merge.tags}}
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, caseType, isActive])
}

// Retainer agreement — one current instance per case. Lifecycle:
//   DRAFT (auto-rendered) → LAWYER_APPROVED (lawyer signs off) →
//   SIGNED (client e-signs in-house) → (terminal).
// VOID is for replacement when terms change mid-case.
//
// We snapshot contentMd at approval time so future template edits don't
// retroactively change what was signed.
model RetainerAgreement {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  caseId            String   @unique @db.Uuid
  templateId        String?  @db.Uuid       // origin template (nullable when freeform)
  status            RetainerStatus @default(DRAFT)
  contentMd         String   @db.Text       // rendered Markdown — frozen on LAWYER_APPROVED
  // Lawyer attestation
  approvedById      String?  @db.Uuid
  approvedBy        User?    @relation("RetainerApprovedBy", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  approvedIp        String?
  approvedUserAgent String?
  // Client signature (typed name in 5.2; signature canvas comes later)
  signedName        String?
  signedAt          DateTime?
  signedIp          String?
  signedUserAgent   String?
  signatureSvg      String?  @db.Text       // base64 PNG/SVG when canvas pad lands
  // Lifecycle
  voidedAt          DateTime?
  voidedReason      String?
  createdBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, status])
}

enum RetainerStatus {
  DRAFT
  LAWYER_APPROVED
  SIGNED
  VOID
}

// ─── Phase 5.3: Document collection ────────────────────────────────────────

// DocumentChecklistTemplate — per firm, per caseType. Same selection
// semantics as RetainerTemplate (most specific active wins; null caseType
// is the firm-wide default fallback).
//
// itemsJson shape:
//   [{
//     key: string,            // snake_case, unique within template
//     label: string,
//     description?: string,   // shown to the client on the public page
//     required?: boolean,
//     accept?: string[],      // mime types or extensions: ['application/pdf', '.png']
//     maxSizeMb?: number      // per-file cap; default 25
//   }]
model DocumentChecklistTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  caseType    String?
  name        String
  description String?
  itemsJson   Json
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collections DocumentCollection[]

  @@index([tenantId, caseType, isActive])
}

// DocumentCollection — one per case. Tracks the public link state and
// the snapshot of items at "send" time so future template edits don't
// retroactively change what the client sees.
//
// Lifecycle:
//   DRAFT       → SENT (link generated; client can upload)
//                → LOCKED (client clicked Submit; link inert)
//                → UNLOCKED (admin override; back to upload-allowed)
// LOCKED ↔ UNLOCKED toggles by FIRM_ADMIN / BRANCH_MANAGER only.
model DocumentCollection {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  caseId               String   @unique @db.Uuid    // one current collection per case
  templateId           String?  @db.Uuid
  template             DocumentChecklistTemplate? @relation(fields: [templateId], references: [id])
  status               DocumentCollectionStatus @default(DRAFT)
  itemsJson            Json     // snapshot of required items for THIS case
  // Public link
  publicTokenHash      String?  @unique
  publicTokenExpiresAt DateTime?
  sentAt               DateTime?
  sentVia              String?  // 'sms' | 'email'
  // Lock state (per docs invariant: "Document collection link locks
  // after client submission; only Law Firm Admin or Branch Manager can unlock")
  submittedAt          DateTime?  // client clicked Submit on the public page
  lockedAt             DateTime?
  unlockedAt           DateTime?
  unlockedById         String?  @db.Uuid
  unlockReason         String?
  createdBy            String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  uploads              DocumentUpload[]

  @@index([tenantId, status])
}

enum DocumentCollectionStatus {
  DRAFT
  SENT
  LOCKED
  UNLOCKED
}

// DocumentUpload — one row per file actually uploaded. Versioning via
// supersededAt: re-uploading the same itemKey marks the prior row
// superseded AND deletes the prior R2 object (per docs invariant:
// "Document re-upload deletes prior version on disk").
model DocumentUpload {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  collectionId    String   @db.Uuid
  collection      DocumentCollection @relation(fields: [collectionId], references: [id])
  caseId          String   @db.Uuid
  itemKey         String   // matches an item in the collection's itemsJson
  // Source of upload — null uploadedById = client uploaded via public link.
  uploadedById    String?  @db.Uuid
  uploadedByName  String?  // for client uploads (typed name)
  // File metadata
  fileName        String
  contentType     String
  sizeBytes       Int
  r2Key           String   // path in the bucket
  sha256          String?  // hex digest, optional integrity check
  // Versioning
  supersededAt    DateTime?
  supersededById  String?  @db.Uuid
  // Phase 8.2 — auto-classified category (or manually re-classified).
  // aiCategory matches a checklist item key when one fits; otherwise free
  // form. aiConfidence is 0..1 self-reported; null = never classified.
  aiCategory      String?
  aiCategoryLabel String?
  aiConfidence    Float?
  aiClassifiedAt  DateTime?
  aiClassifyMode  String?
  createdAt       DateTime @default(now())

  @@index([tenantId, caseId, itemKey, supersededAt])
  @@index([collectionId])
}

// ─── Phase 5.4: IRCC correspondence log ────────────────────────────────────

// IrccCorrespondence — chronological per-case log of interactions with
// IRCC. Manual: there's no public IRCC API to scrape. Filer/lawyer adds
// entries as events happen so the case timeline tells the full story.
//
// Type vocabulary (string for forward-compat):
//   'submission'             — file uploaded to IRCC portal
//   'rfe_received'           — IRCC requested additional evidence
//   'rfe_responded'          — firm responded to RFE
//   'biometrics_requested'   — IRCC biometrics letter issued
//   'biometrics_completed'   — client completed biometrics
//   'interview_scheduled'    — IRCC interview booked
//   'interview_completed'    — interview happened
//   'medical_requested'      — IRCC medical exam letter
//   'medical_completed'
//   'decision'               — final decision (approved/refused/withdrawn/returned)
//   'other'
model IrccCorrespondence {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  caseId      String    @db.Uuid
  type        String
  occurredAt  DateTime
  notes       String?
  // Optional FK into a DocumentUpload (e.g. RFE letter, decision letter).
  // Soft FK — we don't enforce referential integrity at the model level
  // because the upload may belong to any collection on the case.
  attachmentUploadId String? @db.Uuid
  recordedById String   @db.Uuid
  createdAt   DateTime  @default(now())

  @@index([tenantId, caseId, occurredAt])
}

// ─── Phase 5.5: Client portal ──────────────────────────────────────────────

// ClientPortalAccount — login record for an end client (the law firm's
// customer). One per Client. Scope='client' JWTs key off this row.
//
// Lifecycle:
//   INVITED  → setup token sent; password not set yet
//   ACTIVE   → password set, can sign in
//   DISABLED → soft-revoke (firm admin can disable)
model ClientPortalAccount {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  clientId    String   @unique @db.Uuid
  client      Client   @relation(fields: [clientId], references: [id])
  email       String   @db.Citext
  passwordHash String?
  status      ClientAccountStatus @default(INVITED)
  invitedAt   DateTime?
  joinedAt    DateTime?
  lastLoginAt DateTime?
  // Setup flow — like /setup for new firms.
  setupTokenHash       String?  @unique
  setupTokenExpiresAt  DateTime?
  invitedById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    ClientPortalSession[]
  pushDevices PushDevice[]

  @@unique([tenantId, email])
}

enum ClientAccountStatus {
  INVITED
  ACTIVE
  DISABLED
}

// Refresh-token sessions for the client portal — kept separate from the
// staff Session table because the keying differs (accountId vs userId).
model ClientPortalSession {
  id               String   @id @default(uuid()) @db.Uuid
  accountId        String   @db.Uuid
  account          ClientPortalAccount @relation(fields: [accountId], references: [id])
  refreshTokenHash String   @unique
  device           String
  ip               String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  revokedAt        DateTime?
}

// ─── Phase 6: AI extraction + form-fill ────────────────────────────────────

// CaseAiData — one row per case. Stores extracted structured data from
// the case's documents + intake submissions, with per-field provenance
// and manual overrides kept separate so re-running AI doesn't blow away
// the lawyer's edits.
//
// dataJson shape varies by case type but normalises around:
//   {
//     applicant: { firstName, lastName, dateOfBirth, gender, citizenship, … },
//     passport: { number, issuedAt, expiresAt, country },
//     contact: { email, phone, address: {...} },
//     travel: [{ country, fromDate, toDate, purpose }],
//     employment: [{ employer, role, fromDate, toDate, country }],
//     education: [{ institution, level, fromDate, toDate, country }],
//     family: { spouse?, children?, dependents? },
//     financial: { proofOfFundsCad?, source? },
//     answers: { /* free-form yes/no answers from intake */ }
//   }
//
// provenanceJson maps "applicant.firstName" → { source: r2Key, confidence }.
// overridesJson is a flat key→value map of lawyer/filer manual edits.
model CaseAiData {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  caseId      String   @unique @db.Uuid
  caseType    String
  status      CaseAiStatus @default(EMPTY)
  dataJson    Json
  provenanceJson Json
  overridesJson Json
  uploadsConsidered Int @default(0)
  lastRunAt   DateTime?
  lastRunById String?  @db.Uuid
  lastError   String?
  // 'real' | 'dry-run' — surfaces in the UI so users know whether the
  // extraction came from a real model call.
  lastMode    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum CaseAiStatus {
  EMPTY
  RUNNING
  READY
  FAILED
}

// PdfFormTemplate — per-firm fillable PDF (typically an IRCC form like
// IMM 1295 / IMM 0008). Source PDF lives in R2; mappingJson maps each
// AcroForm field name to a dotted data-path on CaseAiData.merged
// (extracted + overrides). Generation reads CaseAiData, builds the
// values, fills the PDF, drops the result in R2 + a GeneratedDocument row.
//
// mappingJson shape:
//   [
//     { pdfField: 'family_name',  dataPath: 'applicant.lastName' },
//     { pdfField: 'given_name',   dataPath: 'applicant.firstName' },
//     { pdfField: 'date_of_birth',dataPath: 'applicant.dateOfBirth', format: 'date_yyyymmdd' },
//     { pdfField: 'is_canadian',  dataPath: 'applicant.citizenship', kind: 'checkbox', equals: 'CAN' },
//     ...
//   ]
// Supported `kind`s: 'text' (default), 'checkbox', 'radio'. Optional
// `format`: 'date_yyyymmdd' | 'date_dd_mm_yyyy' | 'phone_e164' (best-effort
// converters, raw text if unset).
model PdfFormTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  caseType    String?
  name        String
  description String?
  // Source PDF lives in R2. fileName + sizeBytes are kept for display only.
  r2Key       String
  fileName    String
  sizeBytes   Int
  // Field names extracted from the PDF on first read, cached for the UI.
  // Refreshed when the source PDF is replaced.
  detectedFieldsJson Json
  mappingJson        Json
  isActive    Boolean  @default(true)
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generated   GeneratedDocument[]

  @@index([tenantId, caseType, isActive])
}

// GeneratedDocument — a filled PDF produced from a PdfFormTemplate +
// CaseAiData snapshot. Lives in R2 alongside the staff/client uploads
// but is firm-generated rather than client-uploaded. Versioned via
// supersededAt: regenerating produces a fresh row and supersedes prior.
model GeneratedDocument {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  caseId          String   @db.Uuid
  templateId      String   @db.Uuid
  template        PdfFormTemplate @relation(fields: [templateId], references: [id])
  fileName        String
  r2Key           String
  sizeBytes       Int
  // Frozen snapshot of the data used to generate THIS PDF — proves what
  // was filled when. JSON is a flat dotted-key map.
  dataSnapshot    Json
  generatedById   String   @db.Uuid
  generatedAt     DateTime @default(now())
  supersededAt    DateTime?
  supersededById  String?  @db.Uuid

  @@index([tenantId, caseId, supersededAt])
  @@index([templateId])
}

// ─── Phase 7: Case-level invoicing + payment ledger ────────────────────────

// CaseInvoice — a billable document tied to a case. Distinct from
// SubscriptionInvoice (per-seat platform billing). Number is unique per
// tenant; format `INV-{YYYY}-{seq}` allocated on create.
//
// Money model: subtotal + tax = total. amountPaid + balance is derived
// from CasePayment ledger sum (allocated-to-invoice rows only). Updates
// to invoice totals or payments call recomputeCaseFinances() which
// re-syncs Case.amountPaidCents + Case.feesCleared from the ledger.
model CaseInvoice {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @db.Uuid
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  caseId          String              @db.Uuid
  case            Case                @relation(fields: [caseId], references: [id])
  branchId        String?             @db.Uuid          // denorm from case for scope filtering
  number          String              // INV-2026-00042
  status          String              @default("DRAFT") // DRAFT | SENT | PARTIAL | PAID | VOID
  currency        String              @default("CAD")
  // Money — recomputed from items on every change
  subtotalCents   Int                 @default(0)
  taxCents        Int                 @default(0)
  totalCents      Int                 @default(0)
  // Lifecycle
  issueDate       DateTime            @default(now())
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?
  voidReason      String?
  notes           String?             @db.Text          // shown to client on invoice
  // Cached rendered PDF in R2 (key only — fetched via signedUrl). Cleared
  // when items mutate / status flips / void; re-rendered on next request.
  pdfR2Key        String?
  pdfRenderedAt   DateTime?
  createdById     String              @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items           CaseInvoiceItem[]
  payments        CasePayment[]

  @@unique([tenantId, number])
  @@index([tenantId, caseId, status])
  @@index([tenantId, branchId, status])
  @@index([tenantId, status, dueDate])
}

// CaseInvoiceItem — one line on an invoice. taxRateBp is in basis points
// (1300 = 13% HST). amountCents = round(qty * unitPrice * (1 + tax/10000)).
// Cascade-deleted with the parent invoice (only DRAFT invoices are mutable
// at the item level — server enforces).
model CaseInvoiceItem {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  invoiceId       String      @db.Uuid
  invoice         CaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description     String
  quantity        Int         @default(1)
  unitPriceCents  Int
  taxRateBp       Int         @default(0)
  amountCents     Int                                  // qty * unit * (1 + tax)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())

  @@index([invoiceId, sortOrder])
}

// CasePayment — a money-in event on a case. invoiceId is nullable so
// retainer fees / unallocated deposits can land on the case without
// being tied to a specific invoice. method covers offline channels
// (cash, cheque, etransfer, wire) plus the manual `card` entry and
// the Stripe-driven `stripe` flow (Phase 7.2).
//
// Refunds: refundedCents accumulates partial refunds; status flips to
// REFUNDED when refundedCents == amountCents.
model CasePayment {
  id                    String       @id @default(uuid()) @db.Uuid
  tenantId              String       @db.Uuid
  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  caseId                String       @db.Uuid
  case                  Case         @relation(fields: [caseId], references: [id])
  invoiceId             String?      @db.Uuid
  invoice               CaseInvoice? @relation(fields: [invoiceId], references: [id])
  amountCents           Int
  refundedCents         Int          @default(0)
  currency              String       @default("CAD")
  method                String       // card | cash | etransfer | cheque | wire | stripe
  status                String       @default("COMPLETED") // COMPLETED | PARTIAL_REFUND | REFUNDED | VOIDED
  reference             String?                            // cheque #, etransfer code, etc
  stripePaymentIntentId String?      @unique
  note                  String?
  receivedAt            DateTime     @default(now())
  // Nullable: Stripe-webhook-driven payments have no user actor.
  recordedById          String?      @db.Uuid
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([tenantId, caseId, receivedAt])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
}

// ─── Phase 7.4: Secure messaging (firm ↔ client) ───────────────────────────

// Message — one row per chat-style entry between a client and the firm.
// Per-client thread (cross-case) by default; caseId is optional and lets
// staff tag a message to a specific case for later filtering. SYSTEM
// sender is reserved for events like "case status changed" / "documents
// requested" — not used in 7.4 but pre-allocated.
//
// readByClient / readByStaff are receipt timestamps used to compute
// per-side unread counters.
model Message {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  clientId     String        @db.Uuid
  client       Client        @relation(fields: [clientId], references: [id])
  caseId       String?       @db.Uuid
  case         Case?         @relation(fields: [caseId], references: [id])
  sender       MessageSender
  // Only set when sender = STAFF; nullable for CLIENT and SYSTEM rows.
  senderUserId String?       @db.Uuid
  body         String        @db.Text
  // Reserved for Phase 7.5 (portal document upload) — JSON array of refs.
  attachments  Json?
  readByClient DateTime?
  readByStaff  DateTime?
  createdAt    DateTime      @default(now())

  @@index([tenantId, clientId, createdAt])
  @@index([tenantId, caseId, createdAt])
  @@index([tenantId, sender, readByStaff]) // staff inbox unread query
}

enum MessageSender {
  CLIENT
  STAFF
  SYSTEM
}

// ─── Phase 8.1: AI settings + usage tracking ───────────────────────────────

// One row per tenant. Created lazily on first read; until then the
// firm runs with sensible defaults (enabled, no budget cap, Sonnet).
//
// `monthlyBudgetCents` of 0 means "no cap". `preferredModel` is a free-form
// string so firms can opt into newer Claude models without a schema migration.
model AiSettings {
  tenantId           String   @id @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  enabled            Boolean  @default(true)
  classifyAuto       Boolean  @default(true)
  formFillEnabled    Boolean  @default(true)
  agentEnabled       Boolean  @default(false)
  preferredModel     String   @default("claude-sonnet-4-6")
  monthlyBudgetCents Int      @default(0)
  redactionLevel     String   @default("standard")  // 'standard' | 'strict'
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// One row per Anthropic call. `costCents` is computed at write time from
// the model's published rates so historical totals are stable even if
// pricing changes.
//
// `feature` is a coarse bucket — extract | classify | formfill | agent |
// summary | transcribe — used by the usage dashboard.
//
// `refType` + `refId` cross-reference the originating row (Case for
// extract/formfill, DocumentUpload for classify, CallLog for transcribe,
// etc) so the firm can drill into "which case cost the most this month".
model AiUsage {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  feature            String
  model              String
  inputTokens        Int      @default(0)
  cachedInputTokens  Int      @default(0)
  outputTokens       Int      @default(0)
  costCents          Int      @default(0)
  mode               String   // 'real' | 'dry-run'
  refType            String?
  refId              String?  @db.Uuid
  createdById        String?  @db.Uuid
  createdAt          DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, feature, createdAt])
  @@index([tenantId, refType, refId])
}

// AiAgentRun — one row per autonomous-agent invocation. The 8.3 agent
// only does `missing_docs`; the column is wide so 8.x can layer in
// followup / next_action / etc without a migration.
//
// `steps` is a chronological array: [{ tool, input, output, ts }]. The
// 8.3 agent has exactly one step (compose-then-post-message) but the
// shape supports multi-step agents we'll build later.
//
// `kickedOffById` is null when the cron fires; non-null when staff hits
// "Run agent now".
model AiAgentRun {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  caseId        String   @db.Uuid
  case          Case     @relation(fields: [caseId], references: [id])
  mode          String                             // 'missing_docs' (8.3)
  status        String                             // RUNNING | DONE | ERROR | SKIPPED
  steps         Json     @default("[]")            // [{ tool, input, output, ts }]
  result        Json?
  costCents     Int      @default(0)
  skipReason    String?                            // populated when status=SKIPPED
  kickedOffById String?  @db.Uuid                  // null = cron, otherwise staff user
  startedAt     DateTime @default(now())
  endedAt       DateTime?

  @@index([tenantId, caseId, startedAt])
  @@index([tenantId, status, startedAt])
}

// ─── Phase 9.5: Push notifications ──────────────────────────────────────

// One row per registered device. Exactly one of `userId` or
// `clientPortalAccountId` is set — staff devices link to User; client
// portal devices link to ClientPortalAccount.
//
// `expoPushToken` is unique globally (Expo Push Service rotates them
// when re-installs happen — we upsert by token to keep one row per
// physical device). Tenant is denormalised so the push helper can pull
// "all staff devices for tenant X" without joining through User.
model PushDevice {
  id                    String                @id @default(uuid()) @db.Uuid
  tenantId              String                @db.Uuid
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  userId                String?               @db.Uuid
  user                  User?                 @relation(fields: [userId], references: [id])
  clientPortalAccountId String?               @db.Uuid
  clientPortalAccount   ClientPortalAccount?  @relation(fields: [clientPortalAccountId], references: [id])
  expoPushToken         String                @unique
  platform              String                // 'ios' | 'android' | 'web'
  variant               String                // 'staff' | 'client'
  lastUsedAt            DateTime              @default(now())
  createdAt             DateTime              @default(now())

  @@index([tenantId, variant])
  @@index([userId])
  @@index([clientPortalAccountId])
}

// ─── Phase 10.1: CASL suppression list ──────────────────────────────────
//
// Per-tenant. Honoured by every outbound channel (Twilio SMS, transactional
// email). Distinct from per-Lead `dncFlag` — suppression is keyed on the
// raw value (E.164 phone OR lower-cased email), so it survives lead/case
// churn and can be added on a complaint that doesn't have a Lead row yet.
//
// `source` records who/what added it: 'unsubscribe' | 'complaint' | 'admin'
// | 'bounce'. The suppression UI surfaces this so admins can audit.
model SuppressionEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  channel     String   // 'sms' | 'email'
  value       String   // E.164 phone OR lower-cased email — keying done at insert time
  reason      String?
  source      String   @default("admin") // 'unsubscribe' | 'complaint' | 'admin' | 'bounce'
  addedById   String?  @db.Uuid          // null = system (e.g. CASL unsubscribe link click)
  addedAt     DateTime @default(now())

  @@unique([tenantId, channel, value])
  @@index([tenantId, channel])
}

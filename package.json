{
  "name": "onsecboad",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "bash scripts/ensure-secrets.sh && turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @onsecboad/db generate",
    "db:migrate": "pnpm --filter @onsecboad/db migrate",
    "db:migrate:dev": "sh -c 'set -a && . ./.env && set +a && pnpm --filter @onsecboad/db exec prisma migrate dev \"$@\"' --",
    "db:seed": "pnpm --filter @onsecboad/db seed",
    "db:studio": "sh -c 'set -a && . ./.env && set +a && pnpm --filter @onsecboad/db exec prisma studio'",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
